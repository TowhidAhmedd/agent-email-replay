# ─── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── LANGSMITH ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=email-reply-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── GMAIL / GOOGLE OAUTH ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/sqlite/email_agent.db

# ─── CHROMADB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ─── APP ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_secret_key_at_least_32_chars
APP_ENV=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ─── SCHEDULER ────────────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL_SECONDS=60
MAX_EMAILS_PER_POLL=10

# ─── STREAMLIT ────────────────────────────────────────────────────────────────
STREAMLIT_API_BASE_URL=http://localhost:8000
